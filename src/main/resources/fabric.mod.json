{
	"schemaVersion": 1,
	"id": "retroconvert",
	"version": "${version}",
	"name": "RetroConvert",
	"description": "Automatically converts Babric b1.7.3 mods in the mods folder to Ornithe by rewriting their intermediary bytecode at launch.",
	"authors": [
		"matthewperiut"
	],
	"contact": {
		"homepage": "https://github.com/matthewperiut",
		"sources": "https://github.com/matthewperiut/retroconvert"
	},
	"license": "MIT",
	"icon": "assets/retroconvert/icon.png",
	"environment": "*",
	"entrypoints": {
		"preLaunch": [
			"com.periut.retroconvert.RetroConvert"
		]
	},
	"depends": {
		"fabricloader": ">=0.17.3",
		"minecraft": "1.0.0-beta.7.3"
	}
}
